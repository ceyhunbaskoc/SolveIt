{
  "expo": {
    "name": "solveit-mobile",
    "slug": "solveit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SolveIt sorunları haritada göstermek için konumunuzu kullanır."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SolveIt sorun fotoğrafı yüklemek için galeri erişimi ister.",
          "cameraPermission": "SolveIt sorun fotoğrafı çekmek için kamera erişimi ister."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.solveit.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7a36ded9-8b21-4f5a-ab84-04da8bc47e4a"
      }
    }
  }
}
